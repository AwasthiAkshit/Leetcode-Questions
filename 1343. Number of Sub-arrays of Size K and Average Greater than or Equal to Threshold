class Solution {
    public int numOfSubarrays(int[] arr, int k, int threshold) {
        int n = arr.length;
        int i = 0;
        int j = k - 1;
        int av = 0;
        int sum = 0;
        int count = 0;
        for (int a = 0; a < k; a++) {
            sum = sum + arr[a];
        }
        av = sum / k;
        if (av >= threshold)
            count++;
        if (k == n)
            return count;
        i++;
        j++;
        while (j < n) {
            sum = sum - arr[i - 1] + arr[j];
            av = sum / k;
            if (av >= threshold)
                count++;
            i++;
            j++;
        }
        return count;

    }
}
