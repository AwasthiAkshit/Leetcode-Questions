class Solution {
    public int characterReplacement(String s, int k) {
        int maxCount = 0;
        int maxLen = 0;
        int i = 0;
        int[] freq = new int[26];
        for(int j=0;j<s.length();j++){
            freq[s.charAt(j)-'A']++;
            maxCount = Math.max(maxCount,freq[s.charAt(j)-'A']);
            if((j-i+1)-maxCount>k){
                freq[s.charAt(i)-'A']--;
                i++;

            }
            maxLen = Math.max(maxLen,j-i+1);
            
        }
        return maxLen;
    }
}
